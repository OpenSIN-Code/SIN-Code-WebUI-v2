# Purpose: Template for the docker-compose deployment.
# Copy to .env and fill in real values. Never commit .env.

# Root access token for the UI (generate: openssl rand -hex 32)
SIN_UI_TOKEN=

# Postgres password for the bundled db service
POSTGRES_PASSWORD=

# Vercel AI Gateway key for model access
AI_GATEWAY_API_KEY=

# Optional model tier overrides
# SIN_MODEL_PRO=anthropic/claude-sonnet-4.5
# SIN_MODEL_FAST=openai/gpt-5-mini
# SIN_MODEL_MINI=google/gemini-3-flash
