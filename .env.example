# ──────────────────────────────────────────────────────────────
# SIN-Code WebUI v2 — .env.example
# Copy to .env and fill in. NEVER commit .env or .env*.local.
# ──────────────────────────────────────────────────────────────

# ── Required for AI features ────────────────────────────────────
# Vercel AI Gateway key (or any OpenAI/Anthropic compatible key).
# Format: vck_… for Vercel AI Gateway, or sk-… for direct providers.
AI_GATEWAY_API_KEY=

# ── Optional: model selection ──────────────────────────────────
# Override the default chat model. Default: openai/gpt-5-mini.
# SIN_CHAT_MODEL=anthropic/claude-sonnet-4.5

# ── Required for sin-code backend (production / containerized) ─
# Path to the sin-code binary inside the container.
# For Docker, the binary is at /usr/local/bin/sin-code (set in Dockerfile).
# For local dev, just leave it unset (uses $PATH lookup).
# SIN_CODE_BIN=/usr/local/bin/sin-code

# ── Docker / docker-compose ────────────────────────────────────
# Host port the webui is exposed on (default 8080)
WEBUI_PORT=8080

# Host port the sin-code stdio bridge is exposed on (default 8090)
SIN_CODE_PORT=8090

# Cloudflare Tunnel name (optional, for permanent tunnels)
# Get it from: cloudflared tunnel create sin-code-webui
TUNNEL_NAME=sin-code-webui

# Cloudflare Tunnel token (from `cloudflared tunnel token <name>`)
# Leave empty for dev — use scripts/tunnel-up.sh for a quick tunnel.
TUNNEL_TOKEN=

# ── Application secrets ────────────────────────────────────────
# Optional: 32+ char random string for cookie signing (Next.js).
# Generate with: openssl rand -base64 32
# AUTH_SECRET=
