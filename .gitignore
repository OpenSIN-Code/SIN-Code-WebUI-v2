# ──────────────────────────────────────────────────────────────
# SIN-Code WebUI v2 — .gitignore
# ──────────────────────────────────────────────────────────────
# SECURITY: This file MUST be committed before any `git add .`.
#   `.env*.local` covers `.env.development.local.md` (renamed
#   from env.development.local.md) which contains live secrets
#   (Vercel AI Gateway key, v0 callback tokens). Never commit it.
# ──────────────────────────────────────────────────────────────

# v0 sandbox internal files
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
.vercel/

# Environment variables — MUST NEVER be committed
.env*.local
.env
.env.*
!.env.example

# Common ignores
node_modules/
.next/
out/
build/
dist/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Tooling state (sin-code / sin-brain / sin-goal-mode)
.sin/
.sinator/
.pcache/
sin_goal_mode.db
sin_goal_mode.db-*
*.db
*.db-shm
*.db-wal

# TypeScript
*.tsbuildinfo
next-env.d.ts
